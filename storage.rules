rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // PDF tarifs — lecture publique, écriture réservée aux 2 admins
    match /tarifs/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in [
          'helenemarseille@orange.fr',
          'fauconlily05@gmail.com'
        ];
    }
  }
}
